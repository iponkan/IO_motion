<?xml version="1.0" encoding="utf-8"?><!--
   Governs Auto Backup for API < 31 (see data_extraction_rules.xml for API 31+).
   See https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>
    <!--
      io_motion.db holds workout session history (fitness/health-adjacent data). Excluded from
      backup so it is never uploaded to Google's cloud backup or copied during device transfer
      without an explicit, deliberate opt-in.
    -->
    <exclude domain="database" path="io_motion.db" />
    <exclude domain="database" path="io_motion.db-wal" />
    <exclude domain="database" path="io_motion.db-shm" />
    <exclude domain="database" path="io_motion.db-journal" />
</full-backup-content>