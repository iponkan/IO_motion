<?xml version="1.0" encoding="utf-8"?><!--
   Governs cloud backup and device-to-device transfer for API 31+.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <!--
      io_motion.db holds workout session history (fitness/health-adjacent data). Excluded from
      both cloud backup and device transfer so it is never copied off-device without an
      explicit, deliberate opt-in.
    -->
    <cloud-backup>
        <exclude domain="database" path="io_motion.db" />
        <exclude domain="database" path="io_motion.db-wal" />
        <exclude domain="database" path="io_motion.db-shm" />
        <exclude domain="database" path="io_motion.db-journal" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="io_motion.db" />
        <exclude domain="database" path="io_motion.db-wal" />
        <exclude domain="database" path="io_motion.db-shm" />
        <exclude domain="database" path="io_motion.db-journal" />
    </device-transfer>
</data-extraction-rules>